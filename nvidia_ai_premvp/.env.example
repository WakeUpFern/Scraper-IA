# Variables de entorno — nvidia_ai_premvp
# Copia este archivo a .env y completa los valores.
# NUNCA commitees .env con valores reales.

# Obligatorio: clave de API de NVIDIA (build.nvidia.com → "Get API Key")
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcional: URL base del endpoint OpenAI-compatible de NVIDIA NIM
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Opcional: modelo por defecto (ver catálogo en build.nvidia.com)
NVIDIA_DEFAULT_MODEL=qwen/qwen3.5-122b-a10b

# Opcional: timeout en segundos para cada request
NVIDIA_TIMEOUT_SECONDS=60

# Opcional: tokens máximos en la respuesta
NVIDIA_MAX_TOKENS=16384

# Opcional: temperatura de muestreo (0.0 = determinista, 1.0 = creativo)
NVIDIA_TEMPERATURE=0.60

# Opcional: top_p (nucleo de muestreo)
NVIDIA_TOP_P=0.95
